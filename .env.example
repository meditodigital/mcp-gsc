MCP_TRANSPORT=streamable-http
PUBLIC_BASE_URL=https://example.up.railway.app
MCP_HOST=0.0.0.0
MCP_PORT=3001

GOOGLE_CLIENT_ID=replace-with-google-web-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-web-client-secret
GOOGLE_HOSTED_DOMAIN=meditodigital.com
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/webmasters.readonly

MCP_OAUTH_CLIENT_ID=replace-with-generated-client-id
MCP_OAUTH_CLIENT_SECRET=replace-with-generated-client-secret
MCP_OAUTH_REDIRECT_URIS=replace-with-claude-connector-redirect-uri

DATABASE_URL=replace-with-railway-postgres-url
APP_ENCRYPTION_KEY=replace-with-generated-encryption-key
SESSION_COOKIE_SECRET=replace-with-generated-session-secret

GSC_DATA_STATE=all
GSC_ALLOW_DESTRUCTIVE=false
